# PhishGuard local secrets — copy this file to `.env` and fill in
# your own keys. The real `.env` is gitignored.
#
# Loaded at Flask startup before any code that reads os.environ. Lines
# beginning with `#` are comments. Quotes are stripped. Format is
# KEY=value, one per line.

# VirusTotal API key — required for attachment hash analysis.
# Get a free key at https://www.virustotal.com/gui/join-us (4 req/min,
# 500/day on free tier). Without this, attachment badges show "VT off".
VIRUSTOTAL_API_KEY=

# PhishTank API key — registered users get authed feed access. Without
# this we fall back to URLhaus (also free, no key needed). Register
# at https://phishtank.org/register.php and find the key at
# https://phishtank.org/developer_info.php.
PHISHTANK_API_KEY=

# AbuseIPDB API key — auto-activates when set. Resolves the sender's
# domain to an IP and queries AbuseIPDB for that IP's abuse score.
ABUSEIPDB_KEY=

# urlscan.io API key — auto-activates when set. Searches public
# historical scans for the sender's domain (does NOT submit user URLs
# for scanning). Get a free key at https://urlscan.io/user/apikey.
URLSCAN_API_KEY=

# Opt-in session logging — writes a phishguard_log.txt under the user
# data directory. Set to 1 to enable.
PHISHGUARD_LOG=

# Manual debug mode for Flask. Don't set this for normal use — Electron
# never wants Flask's reloader running.
PHISHGUARD_DEBUG=
